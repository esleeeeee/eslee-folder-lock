<Window x:Class="FolderGate.App.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이은성폴더잠금기 작업 로그"
        Icon="pack://application:,,,/FolderGate.App;component/assets/icons/EsleeFolderLock.ico"
        WindowStartupLocation="CenterOwner"
        Width="820"
        Height="520">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="LogText"
                 FontFamily="Consolas"
                 FontSize="12"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto" />

        <Button Grid.Row="1"
                Content="닫기"
                HorizontalAlignment="Right"
                MinWidth="88"
                Height="32"
                Margin="0,12,0,0"
                IsCancel="True" />
    </Grid>
</Window>
