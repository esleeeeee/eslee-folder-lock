<Window x:Class="FolderGate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:text="clr-namespace:FolderGate.Core.Localization;assembly=FolderGate.Core"
        mc:Ignorable="d"
        Title="{x:Static text:AppText.ProductName}"
        Icon="pack://application:,,,/FolderGate.App;component/assets/icons/eslee-folder-locker.ico"
        MinHeight="640"
        MinWidth="980"
        Height="700"
        Width="1080">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="{x:Static text:AppText.ProductName}"
                           FontSize="26"
                           FontWeight="SemiBold" />
                <TextBlock Text="{x:Static text:AppText.MainSubtitle}"
                           Foreground="#555"
                           Margin="0,4,0,0" />
            </StackPanel>
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding StatusMessage}"
                       Foreground="#245a9a"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Right" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top"
                           Text="{x:Static text:AppText.RegisteredFolders}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <DataGrid ItemsSource="{Binding Folders}"
                          SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static text:AppText.ColumnName}"
                                            Binding="{Binding DisplayName}"
                                            Width="150" />
                        <DataGridTextColumn Header="{x:Static text:AppText.ColumnState}"
                                            Binding="{Binding StateText}"
                                            Width="92" />
                        <DataGridTextColumn Header="{x:Static text:AppText.ColumnMode}"
                                            Binding="{Binding ModeText}"
                                            Width="100" />
                        <DataGridTextColumn Header="{x:Static text:AppText.ColumnRegisteredPath}"
                                            Binding="{Binding Path}"
                                            Width="*" />
                        <DataGridTextColumn Header="{x:Static text:AppText.ColumnLastOperation}"
                                            Binding="{Binding LastOperationText}"
                                            Width="145" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="{x:Static text:AppText.Actions}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <WrapPanel Grid.Row="1"
                           Margin="0,0,0,10">
                    <Button Content="{x:Static text:AppText.AddFolder}"
                            Command="{Binding AddFolderCommand}" />
                    <Button Content="{x:Static text:AppText.RemoveFolder}"
                            Command="{Binding RemoveFolderCommand}" />
                    <Button Content="{x:Static text:AppText.Lock}"
                            Command="{Binding LockCommand}" />
                    <Button Content="{x:Static text:AppText.Unlock}"
                            Command="{Binding UnlockCommand}" />
                    <Button Content="{x:Static text:AppText.ShowLogs}"
                            Command="{Binding ShowLogsCommand}" />
                    <Button Content="{x:Static text:AppText.ChangePassword}"
                            Command="{Binding ChangePasswordCommand}" />
                    <Button Content="{x:Static text:AppText.OpenRecoveryTool}"
                            Command="{Binding OpenRecoveryToolCommand}" />
                    <Button Content="{x:Static text:AppText.RegisterExplorerMenu}"
                            Command="{Binding RegisterExplorerMenuCommand}" />
                    <Button Content="{x:Static text:AppText.UnregisterExplorerMenu}"
                            Command="{Binding UnregisterExplorerMenuCommand}" />
                    <Button Content="{x:Static text:AppText.Cancel}"
                            Command="{Binding CancelOperationCommand}" />
                </WrapPanel>

                <GroupBox Grid.Row="2"
                          Header="{x:Static text:AppText.ProgressStatus}"
                          Padding="12"
                          Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static text:AppText.Phase}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding OperationPhase}" />

                        <TextBlock Grid.Row="1"
                                   Text="{x:Static text:AppText.Items}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,8,0,0">
                            <Run Text="{Binding OperationCompleted}" />
                            <Run Text=" / " />
                            <Run Text="{Binding OperationTotal}" />
                            <Run Text="{x:Static text:AppText.FailedInline}" />
                            <Run Text="{Binding OperationFailed}" />
                        </TextBlock>

                        <TextBlock Grid.Row="2"
                                   Text="{x:Static text:AppText.Time}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,8,0,0">
                            <Run Text="{x:Static text:AppText.ElapsedInline}" />
                            <Run Text="{Binding OperationElapsed}" />
                            <Run Text="{x:Static text:AppText.EtaInline}" />
                            <Run Text="{Binding OperationEta}" />
                        </TextBlock>

                        <TextBlock Grid.Row="3"
                                   Text="{x:Static text:AppText.CurrentPath}"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding OperationCurrentPath}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3"
                          Header="{x:Static text:AppText.LockMode}"
                          Padding="12"
                          Margin="0,0,0,12">
                    <StackPanel>
                        <RadioButton Content="{x:Static text:AppText.QuickMode}"
                                     IsChecked="{Binding IsQuickMode, Mode=TwoWay}"
                                     Margin="0,0,0,8" />
                        <TextBlock Text="{x:Static text:AppText.QuickModeDescription}"
                                   Foreground="#555"
                                   TextWrapping="Wrap"
                                   Margin="22,0,0,10" />
                        <RadioButton Content="{x:Static text:AppText.HardenedMode}"
                                     IsChecked="{Binding IsHardenedMode, Mode=TwoWay}"
                                     Margin="0,0,0,8" />
                        <TextBlock Text="{x:Static text:AppText.HardenedModeDescription}"
                                   Foreground="#555"
                                   TextWrapping="Wrap"
                                   Margin="22,0,0,0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="4"
                          Header="{x:Static text:AppText.SelectedFolder}"
                          Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="105" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static text:AppText.CurrentState}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedState}" />

                        <TextBlock Grid.Row="1"
                                   Text="{x:Static text:AppText.ColumnRegisteredPath}"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding SelectedPath}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />

                        <TextBlock Grid.Row="2"
                                   Text="{x:Static text:AppText.LastTime}"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding SelectedLastOperation}"
                                   Margin="0,10,0,0" />

                        <TextBlock Grid.Row="3"
                                   Text="{x:Static text:AppText.LastResult}"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,0" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Text="{Binding SelectedLastResult}"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0" />

                        <TextBlock Grid.Row="4"
                                   Grid.ColumnSpan="2"
                                   Text="{x:Static text:AppText.MainDisclaimer}"
                                   TextWrapping="Wrap"
                                   Foreground="#444"
                                   Margin="0,18,0,0" />
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>

        <ProgressBar Grid.Row="2"
                     Height="4"
                     Minimum="0"
                     Maximum="100"
                     Value="{Binding OperationProgressPercent}"
                     IsIndeterminate="{Binding IsProgressIndeterminate}"
                     Margin="0,16,0,0" />
    </Grid>
</Window>
